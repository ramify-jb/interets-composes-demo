{
  "name": "ramify-compound-interest-webflow-component",
  "version": "0.1.0",
  "private": true,
  "description": "Webflow Code Component for Ramify compound interest simulator",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "webflow library bundle --public-path http://localhost:4000/ --no-input",
    "share": "webflow library share",
    "dev": "vite",
    "build": "vite build",
    "verify": "npm run typecheck && npm run build && npm run bundle",
    "package:handoff": "rm -rf release && mkdir -p release && tar --exclude='./node_modules' --exclude='./dist' --exclude='./release' --exclude='./.vite' --exclude='./.env' -czf release/ramify-compound-interest-webflow-component.tar.gz ."
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@webflow/data-types": "^1.1.0",
    "@webflow/react": "^1.1.0",
    "@webflow/webflow-cli": "^1.9.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
